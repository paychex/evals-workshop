# Copy this file to `.env` and fill in your keys. `.env` is gitignored.

# --- LangSmith (required for datasets, experiments, and the CI gate) ---
LANGSMITH_API_KEY=<your-langsmith-api-key>
LANGSMITH_PROJECT=evals-workshop          # optional; groups your traces

# --- Model provider (the agent + LLM judges) ---
# Default model is anthropic:claude-sonnet-4-5 (see config.py).
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# To use OpenAI instead, install langchain-openai, set OPENAI_API_KEY,
# and set WORKSHOP_MODEL below.
# OPENAI_API_KEY=<your-openai-api-key>

# Override the model used everywhere (init_chat_model string form).
# Examples: anthropic:claude-sonnet-4-5  |  openai:gpt-4o-mini
# WORKSHOP_MODEL=anthropic:claude-sonnet-4-5

# Override just the judge model (defaults to WORKSHOP_MODEL).
# WORKSHOP_JUDGE_MODEL=anthropic:claude-sonnet-4-5
