# Copy this file to `.env` and fill in your keys. `.env` is gitignored.

# --- LangSmith (required for datasets, experiments, and the CI gate) ---
LANGSMITH_API_KEY=<your-langsmith-api-key>
LANGSMITH_PROJECT=evals-workshop          # optional; groups your traces

# --- Model provider (the agent + LLM judges) ---
# Default model is gpt-5.4-mini, served via azure_openai through Paychex MaaS
# (see config.py). aipe resolves credentials/base URL from MaaS env vars below.
MAAS_CONSUMER_API_KEY=<your-maas-consumer-api-key>
MAAS_ENVIRONMENT_TIER=n2a          # one of: n2a, n1, n0, perf, prod

# Override the model used everywhere (model name only; provider is set below).
# Examples: gpt-5.4-mini  |  gpt-4o-mini
# WORKSHOP_MODEL=gpt-5.4-mini

# Override the model provider (Paychex MaaS). Azure OpenAI hosts OpenAI models.
# WORKSHOP_MODEL_PROVIDER=azure_openai

# Override just the judge model (defaults to WORKSHOP_MODEL).
# WORKSHOP_JUDGE_MODEL=gpt-5.4-mini
